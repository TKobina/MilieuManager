<%= form_with model: @lexeme do |form| %>
<% if @lexeme.errors.any? %>
  <div id="error_explanation">
    <h2><%= pluralize(@lexeme.errors.count, "error") %> prohibited this from being saved:</h2>
    <ul>
      <% @lexeme.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  </div>
<% end %>
  <div>
    <%= form.submit "Save", class: "form-button px-2 py-1 rounded-lg"%>
    <%= hidden_field_tag :current_milieu, @milieu.id %>
    <%= hidden_field_tag :language_id, @language.id %>
  </div>
  <p>
  <div>
    <%= form.text_field :word, class: "text-field"  %>
    <%= form.label :word %></br></br>
  </div>
  <div>
    <%= form.text_field :kind, class: "text-field"  %>
    <%= form.label :kind %></br></br>
  </div>
  <div>
    <%= form.text_field :meaning, class: "text-field"  %>
    <%= form.label :definition %></br></br>
  </div>
  <div>
    <%= text_field_tag :sublexeme_eids, @lexeme.sublexemes.map{|sub| sub.eid}.join(",") , class: "text-field"%>
    <%= form.label :sublexemes %></br></br>
  </div>
  <div>
    <%= form.text_area :details, class: "large-text-area" %>
  </div>
  </p>
<% end %>