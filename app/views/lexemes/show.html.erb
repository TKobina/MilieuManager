<h1><%= @lexeme.word %>
<% if @owner%>
  <sup><%= @lexeme.eid%></sup>
  </h1>
  <%= link_to "Edit", edit_lexeme_path(@lexeme.id, current_milieu: @milieu, language_id: @language.id), data: { controller: "tooltip", tooltip_content_value: "A helpful tip for the link" }, class: "form-button"%>
  <%= button_to "Delete", @lexeme, method: :delete, data: { turbo_confirm: "Are you sure?" }, params: { current_milieu: @milieu, language_id: @language.id } %>
<% else %>
</h1>
<% end %>

<p>
<h4>Part of Speech:</h4> <%= @lexeme.kind %>
<h4>Definition:</h4> <%= @lexeme.meaning %>
<h4>Details:</h4> <%= @lexeme.details %>

<h2>Roots:</h2>
<div>
<% @lexeme.sublexemes.sort.each do |sublex| %>
  <%= link_to sublex.word, lexeme_path(sublex.id,current_milieu: @milieu, language_id: @language.id) %>
  <% if @owner%><sup><%= sublex.eid%></sup><%end%>
  : <%= sublex.meaning%></br>
<% end %>
</div>

<h2>Derivatives:</h2>
<div>
<% @lexeme.suplexemes.sort.each do |suplex| %>
  <%= link_to suplex.word, lexeme_path(suplex.id,current_milieu: @milieu, language_id: @language.id) %>
    <% if @owner%><sup><%= suplex.eid%></sup><%end%>: <%= suplex.meaning%></br>
<% end %>
</div>

<p>
<div>
<%= link_to "Back to Dictionary", lexemes_path(current_milieu: @milieu, language_id: @language.id)%>
</div>