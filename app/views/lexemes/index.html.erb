<% @owner = @language.nation.milieu.owner == current_user%>
<h1><%= @language.name %> Lexemes </h1>
<p>
<% if @owner%>
  <strong><%= link_to "Add Lexeme", new_lexeme_path(current_milieu: @milieu, language_id: @language.id) %></strong>
    <%= form_with url: import_lexemes_path(current_milieu: @milieu, language_id: @language.id), multipart: true do |form| %>
      <%= form.file_field :file, accept: '.csv', class: "text-field" %>
      <%= form.submit "Import", class: "form-button px-2 py-1 rounded-lg" %>
    <% end %>
<% end %>
</p>

<div>
<% @lexemes.each do |lexeme| %>
    <%= link_to lexeme.word, lexeme_path(lexeme.id,current_milieu: @milieu, language_id: @language.id) %>
    <% if @owner%><sup><%= lexeme.eid%>-<%=lexeme.id%></sup><%end%> (<%= lexeme.kind %>): <%= lexeme.meaning %> </br>
<% end %>
</div>