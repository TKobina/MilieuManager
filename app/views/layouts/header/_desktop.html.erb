<header class="flex bg-black font-ledru">
<strong><|></strong><%= link_to "Home", root_path %>

<% if params[:current_milieu].present? %>
    <div><strong><|></strong> <%= link_to "The Story", stories_path(current_milieu: @milieu) %>   </div>
    <div><strong><|></strong> <%= link_to "The Language", languages_path(current_milieu: @milieu) %></div>
    <div><strong><|></strong> <%= link_to "A Chronology", events_path(current_milieu: @milieu) %> </div>
    <div><strong><|></strong> <%= link_to "A Glossary", entities_path(current_milieu: @milieu) %> </div>
    <% if @owner %>
        <div><strong><|></strong><%= link_to "References", references_path(current_milieu: @milieu)%></div>
        <div><strong><|></strong><%= link_to "Relation Classes", relclasses_path(current_milieu: @milieu)%></div>
    <%end%>
<% end %>
</header>