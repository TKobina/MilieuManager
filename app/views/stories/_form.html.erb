<%= form_with model: @story do |form| %>
  <div>
    <%= form.submit "Save", class: "form-button" %>
    <%= hidden_field_tag :current_milieu, @milieu.id %>
  </div>
  <p>
  <div>
    <%= form.text_field :chapter, class: "text-field"  %>
    <%= form.label :chapter, "Chapter Number" %></br></br>
  </div>
  <div>
    <%= form.text_field :title, class: "text-field"  %>
    <%= form.label :title %></br>
  </div>
  <p>
  <div>
    <%= form.check_box :public %>
    <%= form.label "Public?" %></br>
  </div>
  <p>
  <div>
    <%= form.text_area :details, class: "large-text-field" %>
  </div>
  </p>
<% end %>