<h1><%= @entity.kind.titlecase %> <%= @entity.name.titlecase %>
<% if @owner%>
  <sup><%= @entity.eid%></sup> (<%= @entity.public ? "Public" : "Private" %>)</h1>
  <%= link_to "Back", :back, class: "form-button" %></br>
    <%= link_to :edit_reference, edit_reference_path(@entity.reference.id, current_milieu: @milieu)%>
<% else %>
  </h1>
  <%= link_to "Back", :back, class: "form-button" %></br>
<% end %>

<% if @entity.reference&.text["pub"].present? %>
<h3>Details</h3>
<%= markdown(@entity.reference&.text["pub"], @milieu, request) %><p>
<% end %>

<% if @entity.reference&.text["pri"].present? && @private %>
<h3>Private Details</h3>
<%= markdown(@entity.reference&.text["pri"], @milieu, request) %><p>
<% end %>

<% unless @properties.empty? then %>
<ul class="list-disc list-inside pl-2"><h2>Properties</h2>
<% @properties.each do |prop| %>
<div>
  <li class="marker:text-dlavender">
    <% if @owner %>(<%= prop.public == true ? "Public" : "Private" %>) <% end %><%= prop.kind.titleize%>: <%= prop.value%>
  <%= prop.detail %></li>
</div>
<% end %>
<% end %>
</ul>

<% unless @superior_relations.empty? && @inferior_relations.empty? %>
<ul class="list-disc list-inside pl-2"><h2>Relations</h2>
<% end %>
<% unless @superior_relations.empty? %>
  <% @superiors.zip(@superior_relations).sort_by { |sup, rel| sup }.each do |sup, rel| %>
    <div>
      <li class="marker:text-dlavender"><%= rel.relclass.bottomtop&.capitalize %> <%= link_to sup.name, entity_path(sup.id, current_milieu: @milieu) %></li>
    </div>
  <% end %>
  <% end %>

<% unless @inferior_relations.empty? %>
  <% @inferiors.zip(@inferior_relations).sort_by { |inf, rel| inf }.each do |inf, rel| %>
    <div>
      <li class="marker:text-dlavender"><%= rel.relclass.topbottom&.capitalize %> <%= link_to inf.name, entity_path(inf.id, current_milieu: @milieu) %></li>
    </div>
  <% end %>
  <% end %>
</ul>

<div>
<ul class="list-disc list-inside pl-2"><h2>Events</h2>
<% @events.each do |event| %>
  <li class="marker:text-dlavender"><%= event.ydate.to_s %>: <%= link_to event.name, event_path(event.id, current_milieu: @milieu) %></li>
<% end %>
</div>
</ul>
